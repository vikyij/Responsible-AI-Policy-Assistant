PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX_NAME=your_384_dimension_index_name

HF_TOKEN=your_hugging_face_token
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Local development text generation
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:7b
LLM_MAX_TOKENS=800

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://your-frontend.vercel.app

# Render/hosted text generation
# Set LLM_PROVIDER=groq on Render
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_API_KEY=your_groq_api_key
